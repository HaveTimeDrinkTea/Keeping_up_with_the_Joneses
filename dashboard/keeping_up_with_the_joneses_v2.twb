      <aliases enabled='yes' />
      <column caption='Selected Metric' datatype='real' name='[Calculation_0424324120825856]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#10;WHEN &quot;Wealth&quot; THEN AVG([disposable_income_pc])&#10;WHEN &quot;Health&quot; THEN AVG([life_expectancy])&#10;WHEN &quot;Happiness&quot; THEN AVG([life_satisfaction_index])&#10;END' />
      </column>
      <column caption='Highlight Colour' datatype='string' name='[Calculation_0424324121333761]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 2] = &apos;UK Region&apos; AND [is_uk] = 1 THEN &apos;UK Highlight&apos;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;European Region&apos; AND [is_uk] = 0 THEN &apos;Europe Highlight&apos;&#10;ELSE &apos;No Highlight&apos;&#10;END' />
      </column>
      <column caption='Region Full Name' datatype='string' name='[Calculation_0904810785636355]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[region] + &quot;, &quot; + [country]' />
      </column>
      <column caption='Show Region' datatype='boolean' name='[Calculation_0904810802954246]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[is_uk] = 1 OR [Selected Country Set] = TRUE' />
      </column>
      <column caption='Dynamic Treemap Title' datatype='string' name='[Calculation_0904810836893704]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;      UK vs Selected EU Nations: &quot; + [Parameters].[Parameter 1]' />
