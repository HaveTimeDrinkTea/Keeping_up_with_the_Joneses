    <worksheet name='User_Controls'>
      <table>
        <view>
          <datasources>
            <datasource caption='03a_df_regional_wellbeing_6countries_mainland' name='federated.0bp7bgr1f8an7b1avu32q1qwlahz' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Metric Toggle' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Wealth&quot;'>
              <calculation class='tableau' formula='&quot;Wealth&quot;' />
            </column>
            <column caption='Highlight Toggle' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;European Region&quot;'>
              <calculation class='tableau' formula='&quot;European Region&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0bp7bgr1f8an7b1avu32q1qwlahz'>
            <column caption='Selected Metric' datatype='real' name='[Calculation_0424324120825856]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#10;WHEN &quot;Wealth&quot; THEN SUM([disposable_income_pc])&#10;WHEN &quot;Health&quot; THEN SUM([life_expectancy])&#10;WHEN &quot;Happiness&quot; THEN SUM([life_satisfaction_index])&#10;END' />
            </column>
            <column caption='Highlight Colour' datatype='string' name='[Calculation_0424324121333761]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 2] = &apos;UK Region&apos; AND [is_uk] = 1 THEN &apos;UK Highlight&apos;&#10;ELSEIF [Parameters].[Parameter 2] = &apos;European Region&apos; AND [is_uk] = 0 THEN &apos;Europe Highlight&apos;&#10;ELSE &apos;No Highlight&apos;&#10;END' />
            </column>
